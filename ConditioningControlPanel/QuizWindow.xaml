<Window x:Class="ConditioningControlPanel.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sissy Quiz"
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Question fade in -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Score pulse -->
        <Storyboard x:Key="ScorePulseStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Glow pulse (infinite) -->
        <Storyboard x:Key="GlowPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowOverlay"
                             Storyboard.TargetProperty="Opacity"
                             From="0.03" To="0.08" Duration="0:0:2"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar (non-fullscreen only) -->
        <Border x:Name="TitleBar" Grid.Row="0" Background="#252542" Height="36"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sissy Quiz" Foreground="#FF69B4" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button x:Name="BtnCloseTitleBar" Grid.Column="1" Content="✕" Width="36" Height="36"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        Click="BtnCloseTitleBar_Click"
                        ToolTip="Close (Escape)">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

        <!-- Background layers (gradient animated from code-behind) -->
        <Border x:Name="BackgroundBorder">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.4" RadiusX="0.8" RadiusY="0.8">
                    <GradientStop Color="#1A0A2E" Offset="0"/>
                    <GradientStop Color="#0A0514" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Glow overlay -->
        <Border x:Name="GlowOverlay" Opacity="0.05" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.4" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#FF69B4" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Vignette -->
        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
                    <GradientStop Color="Transparent" Offset="0.5"/>
                    <GradientStop Color="#80000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ============ CATEGORY SELECT PANEL ============ -->
        <Grid x:Name="CategorySelectPanel" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
                <!-- Title -->
                <TextBlock Text="SISSY QUIZ" FontSize="58" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="AI-generated personality quiz" Foreground="#808090" FontSize="19"
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Choose your category" Foreground="#B0B0C8" FontSize="22"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Sissy button -->
                <Border x:Name="BtnCategorySissy" Cursor="Hand" CornerRadius="12" Margin="0,0,0,12"
                        Padding="20,16" MouseLeftButtonDown="CategoryButton_Click" Tag="Sissy"
                        MouseEnter="CategoryButton_MouseEnter" MouseLeave="CategoryButton_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FFFFFF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30FF69B4"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1.5</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="Sissy" Foreground="#FF69B4" FontWeight="Bold" FontSize="26"/>
                        <TextBlock Text="How deep into feminization are you really?" Foreground="#808090" FontSize="17" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Bambi button -->
                <Border x:Name="BtnCategoryBambi" Cursor="Hand" CornerRadius="12" Margin="0,0,0,12"
                        Padding="20,16" MouseLeftButtonDown="CategoryButton_Click" Tag="Bambi"
                        MouseEnter="CategoryButton_MouseEnter" MouseLeave="CategoryButton_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FFFFFF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#309B59B6"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1.5</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="Bambi" Foreground="#9B59B6" FontWeight="Bold" FontSize="26"/>
                        <TextBlock Text="How susceptible to conditioning are you?" Foreground="#808090" FontSize="17" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ESC hint -->
                <TextBlock Text="Press ESC to close" Foreground="#404060" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,24,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ============ LOADING PANEL ============ -->
        <Grid x:Name="LoadingPanel" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtLoadingDots" Text="Generating..." FontSize="36" FontWeight="Bold"
                           Foreground="#FF69B4" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtLoadingFlavor" Text="The quiz master is thinking up something devious..."
                           Foreground="#606080" FontSize="19" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ============ QUESTION PANEL ============ -->
        <Grid x:Name="QuestionPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar: progress dots + score -->
            <Grid Grid.Row="0" Margin="40,30,40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress dots -->
                <StackPanel x:Name="ProgressDotsPanel" Orientation="Horizontal" VerticalAlignment="Center"/>

                <!-- Score -->
                <TextBlock x:Name="ScoreText" Grid.Column="1" FontSize="31" FontWeight="Bold"
                           Foreground="#FF69B4" VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <!-- Centered question + answers -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="600" Margin="40,10,40,40">

                <!-- Question text -->
                <Grid Margin="0,0,0,24">
                    <Grid x:Name="QuestionContentGrid" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TranslateTransform/>
                        </Grid.RenderTransform>
                        <TextBlock x:Name="TxtQuestion" FontSize="46" FontWeight="Bold"
                                   Foreground="White" TextWrapping="Wrap" TextAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#9966CC" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Answer buttons -->
                <StackPanel x:Name="AnswersPanel">
                    <Border x:Name="AnswerA" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                            MouseLeftButtonDown="Answer_Click" Tag="0"
                            MouseEnter="Answer_MouseEnter" MouseLeave="Answer_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#20FFFFFF"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="A" FontWeight="Bold" FontSize="24" Foreground="#FF69B4"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtAnswerA" Grid.Column="1" FontSize="22" Foreground="#D0D0E0"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border x:Name="AnswerB" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                            MouseLeftButtonDown="Answer_Click" Tag="1"
                            MouseEnter="Answer_MouseEnter" MouseLeave="Answer_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#20FFFFFF"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="B" FontWeight="Bold" FontSize="24" Foreground="#FF69B4"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtAnswerB" Grid.Column="1" FontSize="22" Foreground="#D0D0E0"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border x:Name="AnswerC" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                            MouseLeftButtonDown="Answer_Click" Tag="2"
                            MouseEnter="Answer_MouseEnter" MouseLeave="Answer_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#20FFFFFF"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="C" FontWeight="Bold" FontSize="24" Foreground="#FF69B4"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtAnswerC" Grid.Column="1" FontSize="22" Foreground="#D0D0E0"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border x:Name="AnswerD" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                            MouseLeftButtonDown="Answer_Click" Tag="3"
                            MouseEnter="Answer_MouseEnter" MouseLeave="Answer_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#20FFFFFF"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="D" FontWeight="Bold" FontSize="24" Foreground="#FF69B4"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtAnswerD" Grid.Column="1" FontSize="22" Foreground="#D0D0E0"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ============ RESULT PANEL ============ -->
        <Grid x:Name="ResultPanel" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="600" Margin="40">
                    <!-- Score header -->
                    <TextBlock Text="YOUR RESULT" FontSize="24" FontWeight="Bold"
                               Foreground="#808090" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <TextBlock x:Name="TxtFinalScore" FontSize="67" FontWeight="Bold"
                               Foreground="#FF69B4" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF69B4" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock x:Name="TxtScoreLabel" FontSize="19" Foreground="#606080"
                               HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <!-- Profile card -->
                    <Border CornerRadius="14" Padding="24,20" Margin="0,0,0,30">
                        <Border.Background>
                            <SolidColorBrush Color="#12FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#40FF69B4" Offset="0"/>
                                <GradientStop Color="#409B59B6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <TextBlock x:Name="TxtProfileText" FontSize="22" Foreground="#C0C0D8"
                                   TextWrapping="Wrap" LineHeight="34" TextAlignment="Center"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnPlayAgain" Content="Play Again" Cursor="Hand"
                                Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="19"
                                BorderThickness="0" Padding="28,14" Margin="0,0,12,0"
                                Click="BtnPlayAgain_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnCloseResult" Content="Close" Cursor="Hand"
                                Background="#20FFFFFF" Foreground="#B0B0C8" FontWeight="Bold" FontSize="19"
                                BorderThickness="1" Padding="28,14"
                                Click="BtnCloseResult_Click">
                            <Button.BorderBrush>
                                <SolidColorBrush Color="#40FFFFFF"/>
                            </Button.BorderBrush>
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ============ ERROR PANEL ============ -->
        <Grid x:Name="ErrorPanel" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                <TextBlock Text="Oops!" FontSize="34" FontWeight="Bold" Foreground="#FF6B6B"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock x:Name="TxtError" FontSize="17" Foreground="#808090"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>
                <Button Content="Try Again" Cursor="Hand"
                        Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="17"
                        BorderThickness="0" Padding="24,12" HorizontalAlignment="Center"
                        Click="BtnPlayAgain_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock Text="Press ESC to close" Foreground="#404060" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>

        </Grid>
    </Grid>
</Window>
