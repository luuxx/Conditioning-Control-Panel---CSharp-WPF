<Window x:Class="ConditioningControlPanel.CompanionPromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customize AI Companion"
        Width="700" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PinkBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PromptTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252542"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background" Value="#404060"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252542" Padding="20,15">
            <StackPanel>
                <TextBlock Text="Customize Your AI Companion"
                           Foreground="{StaticResource PinkBrush}"
                           FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Edit the prompts that control how your companion thinks and responds. Changes are saved automatically when you close this window."
                           Foreground="#808080" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="ChkUseCustom" Content="Enable Custom Prompts"
                              Foreground="White" VerticalContentAlignment="Center"
                              Checked="ChkUseCustom_Changed" Unchecked="ChkUseCustom_Changed"/>
                    <TextBlock Text="(Uncheck to use default prompts)"
                               Foreground="#606060" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="ContentPanel">

                <!-- Section 1: Personality -->
                <Expander IsExpanded="True" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="Personality (Normal Mode)" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Define who your companion is. Their vibe, tone, and what topics they like to talk about.
                            This is used when Slut Mode is OFF.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPersonality" Style="{StaticResource PromptTextBox}"
                                     Height="120" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetPersonality_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 2: Explicit Reaction -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="Explicit Topic Handling" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            How should your companion react when you mention explicit topics in Normal Mode?
                            (In Slut Mode, this is ignored and they respond explicitly.)
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtExplicitReaction" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetExplicitReaction_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 3: Slut Mode -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Slut Mode Personality" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="(Patreon)" Foreground="#9B59B6" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Define the companion's personality when Slut Mode is enabled.
                            This is more explicit and trigger-heavy. Requires Patreon Premium.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSlutMode" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetSlutMode_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 4: Knowledge Base -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="Knowledge Base" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Files, videos, and resources your companion knows about and can recommend.
                            List audio files, video series, creators, etc.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtKnowledgeBase" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetKnowledgeBase_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 5: Context Reactions -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="Screen Awareness Reactions" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            How your companion reacts to different apps and websites you're viewing.
                            The companion receives context like [App: Chrome | Title: Reddit - r/BambiSleep].
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtContextReactions" Style="{StaticResource PromptTextBox}"
                                     Height="180" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetContextReactions_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 6: Output Rules -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="Output Rules" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Control how long responses are, emoji usage, and response frequency.
                            Keep responses short for a texting feel.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputRules" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="Reset" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetOutputRules_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#252542" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnResetAll" Content="Reset All to Defaults"
                        Style="{StaticResource ResetButton}"
                        HorizontalAlignment="Left"
                        Click="ResetAll_Click"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnCancel" Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Width="80" Margin="0,0,10,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="Save"
                            Style="{StaticResource ActionButton}"
                            Width="80"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
